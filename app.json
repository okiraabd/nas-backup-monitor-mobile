{
  "expo": {
    "name": "NAS Backup Monitor",
    "slug": "nas-backup-monitor-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-v4.png",
    "scheme": "nasbackupmonitormobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "id.web.qra.nasbackupmonitor",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#020817",
        "foregroundImage": "./assets/images/adaptive-foreground-v2.png",
        "monochromeImage": "./assets/images/adaptive-foreground-v2.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon-v4.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-mark-v2.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#020817",
          "dark": {
            "image": "./assets/images/splash-mark-v2.png",
            "backgroundColor": "#020817"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f113f35f-4f6a-4408-867e-a741d24ee630"
      }
    },
    "owner": "qra404s-team"
  }
}
